{
  "manifest_version": 3,
  "name": "中文框选朗读 + 视频字幕跟读",
  "version": "1.3.0",
  "description": "网页拖拽框选中文自动朗读；视频字幕区可锁定边播边跟读；10 种音色预设；音量可放大到 200%；支持 Firebase 登录注册和留言板",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "中文框选朗读",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-selection": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "windows": "Alt+Shift+R"
      },
      "description": "开启/关闭框选朗读模式"
    },
    "toggle-subtitle": {
      "suggested_key": {
        "default": "Alt+Shift+V",
        "windows": "Alt+Shift+V"
      },
      "description": "开启/关闭视频字幕跟读模式"
    },
    "stop-speaking": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "windows": "Alt+Shift+S"
      },
      "description": "停止朗读"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
